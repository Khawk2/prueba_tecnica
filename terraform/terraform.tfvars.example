# ============================================================================
# CRITICAL: These are example values. DO NOT use these in production!
# ============================================================================

aws_region   = "us-east-1"
project_name = "franchises-api"
environment  = "development"  # development | staging | production

# Database Configuration
# NOTE: db_password is now auto-generated by Terraform and stored in Secrets Manager
# Only provide if you need a specific password
db_name     = "franchises"
db_username = "admin"
# db_password = null  # Leave null to auto-generate

# SSL Certificate (Optional - for HTTPS)
# Create certificate in ACM first, then provide ARN here
# certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxx"
certificate_arn = ""  # Empty = HTTP only (not recommended for production)

# Monitoring
alert_email = "your-email@example.com"
