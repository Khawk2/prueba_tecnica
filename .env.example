# ============================================================================
# Example Environment Variables - AWS ECS + MongoDB Atlas Ready
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git! Add to .gitignore
# ============================================================================

# ============================================================================
# MONGODB (REQUIRED) - AWS ECS + Local Development
# ============================================================================
# PRIORITY 1: Full MongoDB URI (Recommended - same format as AWS Secrets Manager)
# Format: mongodb+srv://user:password@cluster.mongodb.net/database?options
# AWS Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/franchises?retryWrites=true&w=majority
# Local Dev:  mongodb://admin:password@localhost:27017/franchises?authSource=admin
MONGODB_URI=mongodb://admin:password@localhost:27017/franchises?authSource=admin

# PRIORITY 2: Legacy variables (only if MONGODB_URI not set)
# These are used by docker-compose.local.yml to build the URI
DB_HOST=localhost
DB_PORT=27017
DB_NAME=franchises
DB_USER=admin
DB_PASSWORD=password

# ============================================================================
# REDIS (Optional - disabled in AWS Free Tier)
# ============================================================================
# AWS:       Set to "localhost" (no Redis in Free Tier) or ElastiCache endpoint
# Local Dev: Set to "redis" (docker-compose.local.yml service name)
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
SERVER_PORT=8080

# ============================================================================
# JWT SECURITY
# ============================================================================
# PRODUCCIÓN (prod profile):
#   - REQUERIDO: Sin este valor la app NO inicia
#   - Debe tener mínimo 32 caracteres (256-bit)
#   - Generar con: openssl rand -base64 32
#   - Ejemplo: aB3dE5fG7hI9jK1lM2nO3pQ4rS5tU6vW7xY8zA9bC0dE1fG2hI3jK4=
#
# DESARROLLO (dev profile):
#   - OPCIONAL: Tiene fallback a valor de desarrollo
#   - Pero se recomienda configurar uno propio
#
# ⚠️ NUNCA uses el mismo secret en dev y prod
# ============================================================================
JWT_SECRET=your-256-bit-secret-key-here-minimum-32-characters-long
# JWT_EXPIRATION y JWT_REFRESH_EXPIRATION son fijos en los perfiles

# ============================================================================
# AWS CONFIGURATION (AWS ECS / Fargate)
# ============================================================================
AWS_REGION=us-east-1

# AWS Secrets Manager - ARN of the secret containing app config
# In ECS, this is injected automatically. For local testing:
# AWS_SECRETS_APP_CONFIG_ARN=arn:aws:secretsmanager:us-east-1:ACCOUNT:secret:name

# AWS Credentials - ONLY FOR LOCAL (use IAM Roles in production)
# AWS_ACCESS_KEY=YOUR_ACCESS_KEY_HERE
# AWS_SECRET_KEY=YOUR_SECRET_KEY_HERE

# ============================================================================
# SPRING BOOT - PROFILES
# ============================================================================
# IMPORTANTE: Selecciona el perfil según el entorno
#
# DEV  (Local Development):
#   SPRING_PROFILES_ACTIVE=dev
#   - Usa: application-dev.yml
#   - MongoDB: localhost (Docker o Desktop)
#   - Redis: habilitado (local)
#   - Logs: DEBUG (verbose)
#   - JWT: puede usar secret de prueba
#
# PROD (AWS ECS Production):
#   SPRING_PROFILES_ACTIVE=prod
#   - Usa: application-prod.yml
#   - MongoDB: Atlas (mongodb+srv://)
#   - Redis: deshabilitado (Free Tier)
#   - Logs: INFO (solo errores importantes)
#   - JWT: SECRET REQUERIDO (sin fallback)
#
# NOTA: El backend NO detecta el entorno automáticamente.
# La infraestructura (Terraform/ECS) define el perfil.
# ============================================================================
SPRING_PROFILES_ACTIVE=dev

# ============================================================================
# ARCHITECTURAL PRINCIPLES (DO NOT MODIFY)
# ============================================================================
# 1. EXPLICIT CONFIGURATION
#    - Prod: No fallbacks, all variables required
#    - Dev: Documented fallbacks only
#
# 2. FAIL-FAST
#    - Missing required config = immediate startup failure
#    - No silent degradation
#
# 3. INFRASTRUCTURE-DEFINED ENVIRONMENT
#    - ECS/Task Definition sets SPRING_PROFILES_ACTIVE
#    - Backend does NOT auto-detect environment
#
# 4. SECURITY
#    - Secrets in AWS Secrets Manager (prod)
#    - No hardcoded credentials in code
#    - Masked logging (no credential exposure)
#
# 5. OBSERVABILITY
#    - Structured startup logs
#    - Environment validation at boot
#    - Clear error messages
# ============================================================================
